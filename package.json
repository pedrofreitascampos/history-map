{
  "name": "oikumene",
  "version": "1.0.0",
  "description": "Oikumene — Your inhabited world. Track, discover, and remember every place.",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node server/index.js",
    "test": "jest --forceExit --detectOpenHandles",
    "test:e2e": "node e2e/clean-data.js && playwright test",
    "test:e2e:headed": "node e2e/clean-data.js && playwright test --headed"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.30.1",
    "@aws-sdk/client-s3": "^3.1070.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.4",
    "google-auth-library": "^10.6.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "nedb-promises": "^6.2.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "all-the-cities": "^3.1.0",
    "jest": "^30.3.0",
    "jsdom": "^24.1.3",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/e2e/"
    ]
  }
}
