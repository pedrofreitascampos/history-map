# Copy to .env and fill in your values before running locally.

# Required in production — leave blank in development (a dev fallback is used).
JWT_SECRET=change-me-to-a-long-random-string

# Google OAuth — required for SSO login.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Port (defaults to 3000 if not set).
PORT=3000

# Set to "production" on the server.
NODE_ENV=development

# Optional offsite backup mirror (S3 or Cloudflare R2 — all three required to enable).
# For Cloudflare R2: endpoint = https://<account_id>.r2.cloudflarestorage.com, region = auto
BACKUP_S3_BUCKET=
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
BACKUP_S3_ENDPOINT=
BACKUP_S3_REGION=auto
